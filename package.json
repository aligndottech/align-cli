{
  "name": "@aligndottech/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Align CLI - capture decisions, check alignment, and manage connectors",
  "bin": { "align": "./dist/index.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "conf": "^13.0.1",
    "open": "^10.1.0",
    "execa": "^9.5.2",
    "dotenv": "^16.4.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "eventsource": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/node": "^22.0.0",
    "@types/eventsource": "^1.1.15",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  },
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "files": ["dist", "README.md"]
